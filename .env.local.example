# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# OneSignal Web Push
NEXT_PUBLIC_ONESIGNAL_APP_ID=your_onesignal_app_id
# Server-side key used by /api/email/inbound processing for transactional pushes
ONESIGNAL_API_KEY=your_onesignal_rest_api_key
# Optional if NEXT_PUBLIC_ONESIGNAL_APP_ID is set
ONESIGNAL_APP_ID=your_onesignal_app_id

# OpenRouter API (server-side only)
OPEN_ROUTER_API_KEY=sk-or-your_key
LLM_MODEL=google/gemini-3-flash-preview

# SMTP (fallback if not configured in admin settings)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=📬 Postino <noreply@postino.pro>
SMTP_FROM_NAME="📬 Postino - {senderName}"

# Mailgun (fallback if not configured in admin settings)
MAILGUN_API_KEY=key-your_key
MAILGUN_WEBHOOK_SIGNING_KEY=your_mailgun_webhook_signing_key
MAILGUN_SANDBOX_EMAIL=sandbox123.mailgun.org
MAILGUN_BASE_URL=https://api.mailgun.net

# App URL
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Vercel plan toggle used by server timeout budgets.
# true  => Pro plan limits
# false => Hobby plan limits
PRO_VERCEL=false

# Worker / Cron auth
# Vercel Cron sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your_random_long_secret
# Optional manual trigger secret for POST /api/internal/email-jobs/process
EMAIL_JOBS_WORKER_SECRET=your_optional_manual_worker_secret
# GitHub Actions scheduler target URL
POSTINO_WORKER_URL=https://your-app.vercel.app/api/internal/email-jobs/process

# Supermemory.ai (optional - only needed if memory is enabled in admin settings)
SUPERMEMORY_API_KEY=your_supermemory_api_key

# Google Maps Geocoding API (optional - enables production-grade place geocoding)
# When set, Postino uses Google Maps Geocoding API instead of the free Nominatim service.
# Create a key at https://console.cloud.google.com/ and enable the Geocoding API.
# Can also be configured in Admin Settings -> Geolocation Settings.
GOOGLE_MAPS_API_KEY=AIzaYourGoogleMapsApiKey
